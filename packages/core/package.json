{
  "name": "@libretexts/davis-core",
  "version": "1.6.1",
  "description": "Shared variant definitions and utilities for Davis UI library",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./base.css": "./dist/base.css",
    "./base.v4.css": "./dist/base.v4.css",
    "./theme.css": "./dist/theme.css",
    "./safelist.css": "./dist/safelist.css",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "type": "module",
  "dependencies": {
    "tailwind-variants": "^0.3.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && npm run generate:configs",
    "dev": "tsc --project tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "generate:configs": "node scripts/generate-tailwind-configs.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ui",
    "components",
    "variants",
    "tailwind",
    "design-system"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "LibreTexts, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibreTexts/davis.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
