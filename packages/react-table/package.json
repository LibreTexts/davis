{
  "name": "@libretexts/davis-react-table",
  "version": "1.6.4",
  "description": "Full-featured, accessible DataTable for React built on TanStack Table, styled with the Davis Design System",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18 || ^19 || ^19.0.0-rc",
    "react-dom": "^18 || ^19 || ^19.0.0-rc",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@libretexts/davis-core": "*",
    "@libretexts/davis-react": "*",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.10.8",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0",
    "tailwind-variants": "^0.3.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/testing-library": "^0.2.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^28.1.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build",
    "dev": "vite build --watch",
    "storybook": "storybook dev -p 6008",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "ui",
    "table",
    "datatable",
    "tanstack",
    "tailwind",
    "accessibility",
    "a11y"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "LibreTexts, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibreTexts/davis.git",
    "directory": "packages/react-table"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
