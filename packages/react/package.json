{
  "name": "@libretexts/davis-react",
  "version": "1.0.0",
  "description": "An a11y-first UI library for React",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "LICENSE",
    "tailwind.preset.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./standalone": {
      "types": "./dist/index.standalone.d.ts",
      "import": "./dist/index.standalone.mjs",
      "require": "./dist/index.standalone.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./styles.standalone.css": "./dist/styles.standalone.css",
    "./tailwind.preset": "./tailwind.preset.js",
    "./tailwind.preset.js": "./tailwind.preset.js",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@headlessui/react": "^2.2.0",
    "react": "^18 || ^19 || ^19.0.0-rc",
    "react-dom": "^18 || ^19 || ^19.0.0-rc",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "@libretexts/davis-core": "*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0",
    "tailwind-variants": "^0.3.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.4.5",
    "@storybook/addon-docs": "^8.6.17",
    "@storybook/addon-essentials": "^8.4.5",
    "@storybook/addon-interactions": "^8.4.5",
    "@storybook/react-vite": "^8.4.5",
    "@storybook/testing-library": "^0.2.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "remark-gfm": "^4.0.1",
    "storybook": "^8.6.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build && npx tailwindcss -i ./src/styles.standalone.css -o ./dist/styles.standalone.css --config ./tailwind.standalone.config.js --postcss ./postcss.standalone.config.js --minify",
    "dev": "vite build --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "headlessui",
    "tailwind",
    "accessibility",
    "a11y"
  ],
  "author": "LibreTexts, Inc.",
  "license": "MIT"
}
