{
  "name": "@libretexts/davis-react",
  "version": "1.3.2",
  "description": "An a11y-first UI library for React",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.css"
  ],
  "peerDependencies": {
    "@headlessui/react": "^2.2.0",
    "react": "^18 || ^19 || ^19.0.0-rc",
    "react-dom": "^18 || ^19 || ^19.0.0-rc",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@libretexts/davis-core": "*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0",
    "tailwind-variants": "^0.3.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/testing-library": "^0.2.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^28.1.0",
    "remark-gfm": "^4.0.1",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build && node -e \"require('fs').copyFileSync('src/styles.css', 'dist/styles.css')\"",
    "dev": "vite build --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "headlessui",
    "tailwind",
    "accessibility",
    "a11y"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "LibreTexts, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibreTexts/davis.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
