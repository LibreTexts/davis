{
  "name": "@libretexts/davis-vue",
  "version": "1.3.0",
  "description": "An a11y-first UI library for Vue",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "type": "module",
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.0",
    "@libretexts/davis-core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vue": "^3.4.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vue",
    "ui",
    "components",
    "headlessui",
    "tailwind",
    "accessibility",
    "a11y"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "LibreTexts, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibreTexts/davis.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
