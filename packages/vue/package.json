{
  "name": "@libretexts/davis-vue",
  "version": "1.6.0",
  "description": "An a11y-first UI library for Vue",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.css"
  ],
  "type": "module",
  "peerDependencies": {
    "vue": "^3.4.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.0",
    "@libretexts/davis-core": "*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0",
    "tailwind-variants": "^0.3.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-docs": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/vue3-vite": "^8.6.18",
    "@storybook/testing-library": "^0.2.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "scripts": {
    "build": "vue-tsc -p tsconfig.build.json && vite build && node -e \"require('fs').copyFileSync('src/styles.css', 'dist/styles.css')\"",
    "dev": "vite build --watch",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vue",
    "ui",
    "components",
    "headlessui",
    "tailwind",
    "accessibility",
    "a11y"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "LibreTexts, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibreTexts/davis.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
